{
 "compilerOptions": {
 "target": "ES2020",
 "module": "ESNext",
 "moduleResolution": "Bundler",
 "jsx": "react-jsx",
 "declaration": true,
 "strict": true,
 "skipLibCheck": true,
 "allowJs": true,
 "esModuleInterop": true,
 "forceConsistentCasingInFileNames": true,
 "noEmit": true,
 "lib": ["ES2020", "DOM", "DOM.Iterable"]
 },
 "include": ["src"]
}
